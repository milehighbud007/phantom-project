# Or in Metasploit console:
msfconsole
msf6> load msgrpc Pass=kali ServerHost=127.0.0.1 ServerPort=55552

# Verify it's running
curl -X POST http://127.0.0.1:55552/api/ \
  -H "Content-Type: binary/message-pack" \
  -d "$(echo '{"method":"auth.login","params":["msf","kali"]}' | msgpack-cli pack)"
```

