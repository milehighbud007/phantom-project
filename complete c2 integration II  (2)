## 🔗 Step 2: Create Integrated Server

Create a new file that combines both Flask and FastAPI:

```python
# integrated_server.py
"""
Integrated C2 + Metasploit Server
Combines FastAPI (C2) and Flask (Metasploit) into one application
"""

from fastapi import FastAPI, Request
from fastapi.middleware.wsgi import WSGIMiddleware
from fastapi.middleware.cors import CORSMiddleware
import uvicorn

# Import FastAPI C2 backend
from main import app as fastapi_app

# Import Flask Metasploit app
from app import app as flask_app

# Create combined application
app = FastAPI(
    title="Integrated Red Team Platform",
    description="Enterprise C2 + Metasploit Automation with AI",
    version="2.0.0"
)

# Add CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:3000", "http://localhost:5173"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Mount all FastAPI routes from main.py
for route in fastapi_app.routes:
    app.routes.append(route)

# Mount Flask app under /msf prefix
app.mount("/msf", WSGIMiddleware(flask_app))

@app.get("/")
async def root():
    return {
        "platform": "Integrated Red Team C2 + Metasploit",
        "version": "2.0.0",
        "author": "Jack Cole - Colorado Tech University",
        "endpoints": {
            "c2_api": "/api/*",
            "metasploit_api": "/msf/*",
            "c2_console": "http://localhost:3000",
            "msf_console": "/msf/console",
            "api_docs": "/docs"
        }
    }

@app.get("/health")
async def health_check():
    return {
        "status": "healthy",
        "c2_backend": "operational",
        "metasploit_integration": "operational",
        "ai_learning": "enabled"
    }

if __name__ == "__main__":
    print("=" * 60)
    print("  INTEGRATED RED TEAM PLATFORM")
    print("  C2 Framework + Metasploit Automation")
    print("=" * 60)
    print()
    print("  🎯 C2 API:          http://localhost:8000/api")
    print("  🔧 Metasploit API:  http://localhost:8000/msf")
    print("  📊 Web Console:     http://localhost:3000")
    print("  📖 API Docs:        http://localhost:8000/docs")
    print()
    print("=" * 60)
    
    uvicorn.run(
        "integrated_server:app",
        host="0.0.0.0",
        port=8000,
        reload=True
    )
```

