##@ Quick Actions

quick-scan: check-root ## Quick network scan (nmap + masscan)
	@echo "🔍 Running quick network scan..."
	@read -p "Enter network (e.g., 192.168.1.0/24): " network; \
	echo "Running nmap..."; \
	nmap -sn $$network; \
	echo "Running masscan..."; \
	$(SUDO) masscan $$network -p1-1000 --rate 10000

quick-wireless: check-root wireless-monitor-enable ## Quick wireless scan
	@echo "📡 Quick wireless scan (30 seconds)..."
	timeout 30 $(SUDO) airodump-ng $(WIRELESS_IFACE)mon || true
	@$(MAKE) --no-print-directory wireless-monitor-disable