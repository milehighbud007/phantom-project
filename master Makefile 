stop: ## Stop all services
	@echo "🛑 Stopping PHANTOM platform..."
	
	@# Stop frontend
	@-pkill -f "npm start" 2>/dev/null || true
	@-pkill -f "react-scripts" 2>/dev/null || true
	
	@# Stop backend
	@-pkill -f "integrated_server.py" 2>/dev/null || true
	@-pkill -f "uvicorn" 2>/dev/null || true
	
	@# Stop Metasploit RPC
	@-pkill -f "msfrpcd" 2>/dev/null || true
	
	@# Stop agents
	@-pkill -f "agent.py" 2>/dev/null || true
	
	@# Disable monitor mode if enabled
	@-$(SUDO) airmon-ng stop $(WIRELESS_IFACE)mon 2>/dev/null || true
	
	@# Restart NetworkManager
	@-$(SUDO) systemctl restart NetworkManager 2>/dev/null || true
	
	@echo "✓ All services stopped"

restart: stop run ## Restart entire platform

##@ Testing

test: ## Run all tests
	@echo "🧪 Running tests..."
	cd $(TESTS_DIR) && $(PYTHON) -m pytest -v --cov=../$(BACKEND_DIR) --cov-report=html
	@echo "✓ Tests complete. Coverage report: tests/htmlcov/index.html"

test-backend: ## Test backend only
	@echo "🧪 Testing backend..."
	cd $(TESTS_DIR) && $(PYTHON) -m pytest -v -k "not Frontend"

test-integration: ## Test integration
	@echo "🧪 Testing integration..."
	cd $(TESTS_DIR) && $(PYTHON) -m pytest -v -k "Integration"

test-wireless: check-root wireless-check ## Test wireless tools
	@echo "🧪 Testing wireless tools..."
	@echo "Checking aircrack-ng..."
	@aircrack-ng --help > /dev/null && echo "✓ aircrack-ng OK" || echo "❌ aircrack-ng failed"
	@echo "Checking masscan..."
	@masscan --help > /dev/null 2>&1 && echo "✓ masscan OK" || echo "❌ masscan failed"
	@echo "Checking bettercap..."
	@bettercap --help > /dev/null 2>&1 && echo "✓ bettercap OK" || echo "❌ bettercap failed"
	@echo "Checking reaver..."
	@reaver --help > /dev/null 2>&1 && echo "✓ reaver OK" || echo "❌ reaver failed"

##@ Development

dev-backend: ## Run backend in development mode
	cd $(BACKEND_DIR) && . venv/bin/activate && uvicorn integrated_server:app --reload --host 0.0.0.0 --port $(BACKEND_PORT)

dev-frontend: ## Run frontend in development mode
	cd $(FRONTEND_DIR) && $(NPM) start

logs: ## View backend logs
	tail -f $(BACKEND_DIR)/logs/c2_platform.log

logs-ai: ## View AI learning logs
	tail -f $(BACKEND_DIR)/metasploit_ai_knowledge.json

monitor: ## Monitor system resources
	htop

##@ Database

db-reset: ## Reset database (WARNING: deletes all data)
	@echo "⚠️  Resetting database..."
	@read -p "Are you sure? [y/N] " -n 1 -r; \
	if [[ $$REPLY =~ ^[Yy]$$ ]]; then \
		$(SUDO) -u postgres psql -c "DROP DATABASE c2_database;" || true; \
		$(SUDO) -u postgres psql -c "CREATE DATABASE c2_database;"; \
		$(SUDO) -u postgres psql -c "GRANT ALL PRIVILEGES ON DATABASE c2_database TO c2_user;"; \
		cd $(BACKEND_DIR) && . venv/bin/activate && $(PYTHON) -c "from main import Base, engine; Base.metadata.create_all(bind=engine)"; \
		echo "✓ Database reset"; \
	fi

db-backup: ## Backup database
	@echo "💾 Backing up database..."
	$(SUDO) -u postgres pg_dump c2_database > backup_$$(date +%Y%m%d_%H%M%S).sql
	@echo "✓ Backup complete"

db-restore: ## Restore database from backup
	@echo "📥 Available backups:"
	@ls -1 backup_*.sql 2>/dev/null || echo "No backups found"
	@read -p "Enter backup filename: " backup; \
	$(SUDO) -u postgres psql c2_database < $$backup

##@ Wireless Operations

wireless-monitor-enable: check-root wireless-check ## Enable monitor mode on wireless interface
	@echo "📡 Enabling monitor mode on $(WIRELESS_IFACE)..."
	$(SUDO) airmon-ng check kill
	$(SUDO) airmon-ng start $(WIRELESS_IFACE)
	@echo "✓ Monitor mode enabled"

wireless-monitor-disable: check-root ## Disable monitor mode
	@echo "📡 Disabling monitor mode..."
	$(SUDO) airmon-ng stop $(WIRELESS_IFACE)mon || true
	$(SUDO) systemctl restart NetworkManager
	@echo "✓ Monitor mode disabled"

wireless-scan: check-root wireless-monitor-enable ## Scan for WiFi networks
	@echo "📡 Scanning for WiFi networks..."
	$(SUDO) airodump-ng $(WIRELESS_IFACE)mon

##@ Maintenance

clean: ## Clean build artifacts
	@echo "🧹 Cleaning..."
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type f -name "*.pyc" -delete 2>/dev/null || true
	find . -type d -name "*.egg-info" -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name ".pytest_cache" -exec rm -rf {} + 2>/dev/null || true
	rm -rf $(BACKEND_DIR)/venv 2>/dev/null || true
	rm -rf $(FRONTEND_DIR)/node_modules 2>/dev/null || true
	rm -rf $(FRONTEND_DIR)/build 2>/dev/null || true
	@echo "✓ Cleaned"

clean-logs: ## Clean log files
	@echo "🧹 Cleaning logs..."
	rm -rf $(BACKEND_DIR)/logs/*.log
	@echo "✓ Logs cleaned"

update: ## Update all dependencies
	@echo "📦 Updating dependencies..."
	cd $(BACKEND_DIR) && . venv/bin/activate && $(PIP) install --upgrade -r requirements_integrated.txt
	cd $(FRONTEND_DIR) && $(NPM) update
	@echo "✓ Dependencies updated"

