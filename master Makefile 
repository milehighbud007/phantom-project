.PHONY: help install setup run stop clean test deps check-root wireless-check

# PHANTOM - Penetration & Hacking Automation Network Threat Operations Manager
# Colorado Tech University - Jack Cole Dissertation Project

PYTHON := python3
PIP := pip3
NPM := npm
SUDO := sudo

# Directories
BACKEND_DIR := backend
FRONTEND_DIR := frontend
AGENTS_DIR := agents
TESTS_DIR := tests

# Services
POSTGRES_SERVICE := postgresql
REDIS_SERVICE := redis-server
MSF_RPC_PORT := 55552
BACKEND_PORT := 8000
FRONTEND_PORT := 3000

# Wireless Interface
WIRELESS_IFACE := wlan1

##@ General

help: ## Display this help
	@awk 'BEGIN {FS = ":.*##"; printf "\n\033[1m PHANTOM - Red Team C2 Platform\033[0m\n\n\033[1mUsage:\033[0m\n  make \033[36m<target>\033[0m\n"} /^[a-zA-Z_-]+:.*?##/ { printf "  \033[36m%-15s\033[0m %s\n", $$1, $$2 } /^##@/ { printf "\n\033[1m%s\033[0m\n", substr($$0, 5) } ' $(MAKEFILE_LIST)

##@ Installation

check-root: ## Check if running as root (required for wireless tools)
	@if [ "$$(id -u)" -ne 0 ]; then \
		echo "❌ Must run as root for wireless tools. Use: sudo make <target>"; \
		exit 1; \
	else \
		echo "✓ Running as root"; \
	fi

deps: ## Install system dependencies
	@echo "📦 Installing system dependencies..."
	$(SUDO) apt update
	$(SUDO) apt install -y \
		python3 python3-pip python3-venv \
		nodejs npm \
		postgresql postgresql-contrib \
		redis-server \
		nmap masscan \
		aircrack-ng \
		reaver \
		bettercap \
		git curl wget \
		net-tools iproute2 \
		libpcap-dev libssl-dev
	@echo "✓ System dependencies installed"

wireless-tools: check-root ## Install wireless attack tools
	@echo "📡 Installing wireless tools..."
	$(SUDO) apt install -y \
		aircrack-ng \
		airmon-ng \
		airodump-ng \
		aireplay-ng \
		reaver \
		bettercap \
		macchanger
	@echo "Installing trackerjacker..."
	$(SUDO) $(PIP) install trackerjacker
	@echo "Installing wifite..."
	$(SUDO) apt install -y wifite || $(SUDO) $(PIP) install wifite2
	@echo "Installing wifiphisher (already in project)..."
	cd $(BACKEND_DIR) && $(SUDO) $(PIP) install -r wifiphisher_requirements.txt
	@echo "✓ Wireless tools installed"

metasploit: ## Install Metasploit Framework
	@echo "🎯 Installing Metasploit..."
	@if ! command -v msfconsole > /dev/null; then \
		curl https://raw.githubusercontent.com/rapid7/metasploit-omnibus/master/config/templates/metasploit-framework-wrappers/msfupdate.erb > msfinstall && \
		chmod 755 msfinstall && \
		./msfinstall && \
		rm msfinstall; \
	fi
	@echo "✓ Metasploit installed"

install: deps metasploit wireless-tools ## Install all dependencies
	@echo "✓ Full installation complete"

setup: ## Setup project (create venv, install Python packages)
	@echo "🔧 Setting up PHANTOM platform..."
	
	# Backend setup
	@echo "Setting up backend..."
	cd $(BACKEND_DIR) && $(PYTHON) -m venv venv
	cd $(BACKEND_DIR) && . venv/bin/activate && $(PIP) install --upgrade pip
	cd $(BACKEND_DIR) && . venv/bin/activate && $(PIP) install -r requirements_integrated.txt
	
	# Frontend setup
	@echo "Setting up frontend..."
	cd $(FRONTEND_DIR) && $(NPM) install
	
	# Database setup
	@echo "Setting up database..."
	$(SUDO) systemctl start $(POSTGRES_SERVICE)
	$(SUDO) -u postgres psql -c "CREATE DATABASE c2_database;" || true
	$(SUDO) -u postgres psql -c "CREATE USER c2_user WITH PASSWORD 'SecurePassword123';" || true
	$(SUDO) -u postgres psql -c "GRANT ALL PRIVILEGES ON DATABASE c2_database TO c2_user;" || true
	
	# Create database tables
	cd $(BACKEND_DIR) && . venv/bin/activate && $(PYTHON) -c "from main import Base, engine; Base.metadata.create_all(bind=engine)"
	
	@echo "✓ Setup complete"

##@ Operations

wireless-check: check-root ## Check wireless interface and capabilities
	@echo "📡 Checking wireless interface: $(WIRELESS_IFACE)"
	@if ip link show $(WIRELESS_IFACE) > /dev/null 2>&1; then \
		echo "✓ Interface $(WIRELESS_IFACE) exists"; \
		iwconfig $(WIRELESS_IFACE) 2>/dev/null || echo "⚠️  Interface not wireless-capable"; \
	else \
		echo "❌ Interface $(WIRELESS_IFACE) not found"; \
		echo "Available interfaces:"; \
		ip link show | grep -E '^[0-9]+:' | awk '{print $$2}' | sed 's/:$$//'; \
		exit 1; \
	fi

start-services: ## Start required services (PostgreSQL, Redis, MSF RPC)
	@echo "🚀 Starting services..."
	
	# Start PostgreSQL
	@echo "Starting PostgreSQL..."
	$(SUDO) systemctl start $(POSTGRES_SERVICE)
	$(SUDO) systemctl enable $(POSTGRES_SERVICE)
	
	# Start Redis
	@echo "Starting Redis..."
	$(SUDO) systemctl start $(REDIS_SERVICE)
	$(SUDO) systemctl enable $(REDIS_SERVICE)
	
	# Start Metasploit RPC
	@echo "Starting Metasploit RPC..."
	@if ! pgrep -f msfrpcd > /dev/null; then \
		msfrpcd -P kali -U msf -S -a 127.0.0.1 -p $(MSF_RPC_PORT) & \
		sleep 3; \
	fi
	
	@echo "✓ Services started"

start-backend: ## Start integrated backend (C2 + Metasploit)
	@echo "🔧 Starting PHANTOM backend..."
	cd $(BACKEND_DIR) && . venv/bin/activate && $(PYTHON) integrated_server.py &
	@echo "✓ Backend started on port $(BACKEND_PORT)"

start-frontend: ## Start React frontend
	@echo "🎨 Starting frontend..."
	cd $(FRONTEND_DIR) && $(NPM) start &
	@echo "✓ Frontend started on port $(FRONTEND_PORT)"

start-agent: ## Start C2 agent (for testing)
	@echo "🤖 Starting test agent..."
	cd $(AGENTS_DIR) && $(PYTHON) agent.py &

